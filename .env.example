# SHI Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Bot will not start without these
# ===========================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Solana RPC URL (Helius, QuickNode, or public)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (optional but recommended for better rate limits)
HELIUS_API_KEY=

# Database URL (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/shi

# ===========================================
# OPTIONAL - Defaults will be used if not set
# ===========================================

# Redis URL (for caching and rate limiting)
# If not set, falls back to in-memory cache
REDIS_URL=redis://localhost:6379

# Admin Telegram User IDs (comma-separated)
# These users can use /ban, /unban, /stats commands
ADMIN_USER_IDS=

# Premium User IDs (comma-separated)
# These users get higher rate limits
PREMIUM_USER_IDS=

# Rate Limits
TELEGRAM_RATE_LIMIT_PER_USER=10
TELEGRAM_RATE_LIMIT_GLOBAL=100

# SLA Configuration
SLA_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# DEVELOPMENT ONLY
# ===========================================

# Enable debug mode (more verbose logging)
DEBUG=false

# Use testnet instead of mainnet
USE_TESTNET=false
